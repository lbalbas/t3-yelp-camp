generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Campground {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  price       String
  description String
  image       String
  location      String?
  lat           Float?
  lng           Float?
  averageRating Float     @default(0)
  creatorId     String
}

model Review {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  rating      Int
  text        String
  creatorId   String
  publishedAt DateTime @default(now())
  campgroundId String   @map("campgroundId") @db.ObjectId
}
